dcf6c36d5c1997945b204ccddfcc7453fcaef23783da5aac1bd54424e29162a4,castillo2018,sea_level_indicator,ABSTRACT,narrative_fallback_1,,,inferred_map,,-35.0,MSL,reported,marine_terrace,narrative fallback: submerged geomorphic sea-level feature,"[-37.5, -32.5]","""LGM""",stratigraphic_context,"marine terrace at ABSTRACT, reported around 35 m depth",ABSTRACT,"Late Quaternary subsidence of Santa Catalina Island, California Continental Borderland, demonstrated by seismic-reflection data and fossil assemblages from submerged marine terraces",https://doi.org/10.1130/B31738.1,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""ABSTRACT"", ""quote_or_paraphrase"": ""Submerged paleoshorelines and terraces surrounding Santa Catalina Island and the Pilgrim/Kidney Banks in the California Continental Borderland demonstrate late Quaternary tectonic subsidence, in contrast to the other islands of the California Continental Borderland that are experiencing tectonic uplift. We used high-resolution seismicreflection profiles to map a terrace package containing 16 successive parasequences surrounding Santa Catalina Island, preserved at depths from 30 to 470 m below modern mean sea level. The Pilgrim/Kidney Banks are surrounded by a terrace package containing 13 successive par""}","{""reported_elevation_m"": null, ""reported_depth_m"": 35.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""stratigraphic_context"", ""relation"": ""unknown"", ""age_ka"": ""LGM"", ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-35,-35,-35,-35
6e7c67c6e8b13af0ea03ddff861abdc45cda239416909e151b0265a9cbab0019,castillo2018,sea_level_indicator,Bottom Sampling and Recovery of Macrofossils and Microfossils,narrative_fallback_2,,,inferred_map,,-110.0,MSL,reported,marine_terrace,narrative fallback: submerged geomorphic sea-level feature,"[-112.5, -107.5]","""LGM""",stratigraphic_context,"marine terrace at Bottom Sampling and Recovery of Macrofossils and Microfossils, reported around 110 m depth",Bottom Sampling and Recovery of Macrofossils and Microfossils,"Late Quaternary subsidence of Santa Catalina Island, California Continental Borderland, demonstrated by seismic-reflection data and fossil assemblages from submerged marine terraces",https://doi.org/10.1130/B31738.1,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""Bottom Sampling and Recovery of Macrofossils and Microfossils"", ""quote_or_paraphrase"": ""Last Glacial Maximum (LGM) terrace surface between water depths of 125 and 95 m (Fig. 2, inset 2). The LGM transgressive surface is present in outcrop in the two submarine canyons, which have significantly incised the LGM terrace, with the best exposure of LGM strata occurring near Long Point (dive NA075-H1556). We used a combination of multichannel seismic (MCS) and chirp subbottom profiles collected by Stanford University in 2014 and 2015 (Fig. 2, inset 2) to visually identify and navigate to key sedimentary horizons exposed on the walls of the submarine canyon. Poorly consolidated sediment on the""}","{""reported_elevation_m"": null, ""reported_depth_m"": 110.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""stratigraph