a400f92eabff659c2bc6a71f5d29da1d9ec33cf757b8895e2838093b84e38617,pretorius2016,sea_level_indicator,Shoreline Genesis,narrative_fallback_1,,,inferred_map,,-28.0,MSL,reported,submerged_beach,narrative fallback: submerged geomorphic sea-level feature,"[-30.5, -25.5]",null,other,"submerged beach at Shoreline Genesis, reported around 28 m depth",Shoreline Genesis,Submerged shoreline preservation and ravinement during rapid postglacial sea-level rise and subsequent “slowstand”,https://doi.org/10.1130/B31381.1,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""Shoreline Genesis"", ""quote_or_paraphrase"": ""The subsidiary shorelines that occur landward of the main barrier shoreline appear to be back-stepped remnants of smaller barriers that formed during transgression up to a depth of 28 m. These are likely to have formed after the initial slowstand that allowed the main barrier to form, and they mark a second, slow migration of the shoreline over the coastal profile at shallower depths, producing smaller, more poorly preserved barrier remnants.""}","{""reported_elevation_m"": null, ""reported_depth_m"": 28.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""other"", ""relation"": ""unknown"", ""age_ka"": null, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-28,-28,-28,-28
10f08a348f49b836e38381e0dae45c6676d29d60628b1f3d41141c95ba32abd9,pretorius2016,sea_level_indicator,Preservation by Overstepping,narrative_fallback_2,,,inferred_map,,-60.0,MSL,reported,submerged_beach,narrative fallback: submerged geomorphic sea-level feature,"[-62.5, -57.5]",null,other,"submerged beach at Preservation by Overstepping, reported around 60 m depth",Preservation by Overstepping,Submerged shoreline preservation and ravinement during rapid postglacial sea-level rise and subsequent “slowstand”,https://doi.org/10.1130/B31381.1,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""Preservation by Overstepping"", ""quote_or_paraphrase"": ""The effect of increasing back-barrier accommodation can be amplified by a reduced shoreline gradient (e.g., Fig. 4). Such a scenario is considered to foster overstepping and preservation of the back-barrier profile (Storms et al., 2008). Lorenzo-Trueba and Ashton (2014) demonstrated that this factor alone may account for the overstepping process without any associated rapid rise in sea level. However, when placed into the context of the core data and geochronology, we prefer the former argument of an increased rate of sea-level rise, acting in combination with the influence of the subdued antecedent backbarrier topography, as being responsible for overst""}","{""reported_elevation_m"": null, ""reported_depth_m"": 60.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""other"", ""relation"": ""unknown"", ""age_ka"": null, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-60,-60,-60,-60
