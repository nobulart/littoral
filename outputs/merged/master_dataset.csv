9986da72ad7edb075a2c0a83ef0d2079fe15d2064b39c51972ed1ef407996bb3,gharibreza2016,sea_level_indicator,3.2. Darango Bay,narrative_fallback_1,,,inferred_map,,-14.6,MSL,reported,submerged_beach,narrative fallback: submerged geomorphic sea-level feature,"[-17.1, -12.1]",null,other,"submerged beach at 3.2. Darango Bay, reported around 14.6 m depth",3.2. Darango Bay,Evolutionary trend of paleoshorelines in the Coastal Makran zone (Southeast Iran) since the mid-Holocene,https://doi.org/10.1016/j.quaint.2015.06.030,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""3.2. Darango Bay"", ""quote_or_paraphrase"": ""A total of 32 (D1 to D32) superficial outcrop of FSST with 2200 m width were identified in Darango Bay (Fig. 4). The first superficial outcrop of a paleoshoreline is located at 14.6 m elevation and 2200 m away from the present shoreline. An old estuary 188 m wide, separated from the sea by new coastal ridges, was identified. Old tidal channels with 2 m depth were detected between the D30 and D27 paleoshoreline. Surveying of paleoshorelines showed that D22 and D31 are well-preserved geoindicators for dating and evaluation of coastal progradation. Therefore, ages of the paleoshorelines were calculated to be 1793 \u00b1 46 Cal BP and 633 \u00b1 45 Cal BP based on radiocarbon dating of collected articulate fossils.""}","{""reported_elevation_m"": null, ""reported_depth_m"": 14.6, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""other"", ""relation"": ""unknown"", ""age_ka"": null, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-14.6,-14.6,-14.6,-14.6
3974bf6cd1f63d1fa468e2219543ba446e954cf5498ca60aa77fad2c605c0cfc,gharibreza2016,sea_level_indicator,3.3. Chabahar Bay,narrative_fallback_2,,,inferred_map,,-15.0,MSL,reported,submerged_beach,narrative fallback: submerged geomorphic sea-level feature,"[-17.5, -12.5]",null,other,"submerged beach at 3.3. Chabahar Bay, reported around 15 m depth",3.3. Chabahar Bay,Evolutionary trend of paleoshorelines in the Coastal Makran zone (Southeast Iran) since the mid-Holocene,https://doi.org/10.1016/j.quaint.2015.06.030,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""3.3. Chabahar Bay"", ""quote_or_paraphrase"": ""Chabahar bay, previously studied by Gharibreza and Motamed (2006), shows 21 paleoshorelines, with the oldest located at 15 m above the present shoreline. These fossil beaches are superficial outcrops of FSST and steps of coastal progradation arranged over 5300 m width. Specific species of undisturbed articulate marine bivalve mollusks in Chabahar Bay were Cardina, Tellina, Mercenaria, Anodontia, Arca, and Anadara. Several species of gastropods such as Bursa, Architectonica, Oliva, Bula, Cyprea, Polinicess, and Murex were identified in the Chabahar Bay. Paleoshorelines C0, C1, C7, and C21 were chosen to calculate rates of shoreline movement based on thei""}","{""reported_elevation_m"": null, ""reported_depth_m"": 15.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""other"", ""relation"": ""unknown"", ""age_ka"": null, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-15,-15,-15,-15
