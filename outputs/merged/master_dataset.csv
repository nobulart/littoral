641f58fd2db63e2b4e8f22b3c65665a4ae936bb46f13079f9420ac9d24b91a3b,foglini2015,sea_level_indicator,Sikka il-Bajda,narrative_fallback_10,,,inferred_map,,-130.0,MSL,reported,submerged_beach,narrative fallback: submerged geomorphic sea-level feature,"[-132.5, -127.5]","""LGM""",stratigraphic_context,"submerged beach at Sikka il-Bajda, reported around 130 m depth",Sikka il-Bajda,Late Quaternary coastal landscape morphology and evolution of the Maltese Islands (Mediterranean Sea) reconstructed from high-resolution seafloor data,https://doi.org/10.1144/SP411.12,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""Sikka il-Bajda"", ""quote_or_paraphrase"": ""t is characterized by a wide variety of terrestrial and marine geomorphic features of different genesis. (b) Bathymetric profiles across the shelf edge showing the different morphological configurations of the LGM palaeoshoreline (located at 2130 m). As in (a), the grey area in the profiles shows the features submerged during the LGM and the brownish area the features emerged during the LGM. Profile locations are given in (a).""}","{""reported_elevation_m"": null, ""reported_depth_m"": 130.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""stratigraphic_context"", ""relation"": ""unknown"", ""age_ka"": ""LGM"", ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-130,-130,-130,-130
99c8f6c2a6f547213c6235a61ef49c9b73ad9de02eee5f1226c1fc90d698d19c,foglini2015,sea_level_indicator,Submergence of the Maltese palaeolandscape after the Last Glacial Maximum,narrative_fallback_11,,,inferred_map,,-130.0,MSL,reported,wave_cut_notch_or_bench,narrative fallback: submerged geomorphic sea-level feature,"[-132.5, -127.5]",20.0,stratigraphic_context,"wave cut notch or bench at Submergence of the Maltese palaeolandscape after the Last Glacial Maximum, reported around 130 m depth",Submergence of the Maltese palaeolandscape after the Last Glacial Maximum,Late Quaternary coastal landscape morphology and evolution of the Maltese Islands (Mediterranean Sea) reconstructed from high-resolution seafloor data,https://doi.org/10.1144/SP411.12,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""Submergence of the Maltese palaeolandscape after the Last Glacial Maximum"", ""quote_or_paraphrase"": ""an average rate of 5 mm a21 (Lambeck et al. 2011). By 14.4 ka, the sea level had dropped to 2100 m. The land bridge had narrowed to less than 10 km and a good part of the shore platform associated with the 2130 m palaeoshoreline had been drowned. By 12.9 ka, the land bridge had become largely submerged and the Maltese archipelago became disconnected from Sicily; the archipelago at this time had an area of 720 km2 , which is more than twice the present surface area. The islands of Malta, Gozo and Comino were connected until 8.6 ka, when the Sikka l-Bajda limestone plateau became an island. Sea-level rise during the following few thousand years submerged the remaining 65 km2 of palaeolandscape to give rise to the current configuration of the Maltese Islands.""}","{""reported_elevation_m"": null, ""reported_depth_m"": 130.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""stratigraphic_context"", ""relation"": ""unknown"", ""age_ka"": 20.0, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-130,-130,-130,-130
