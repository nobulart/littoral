9188e7fb5f5674faded391b7a001f123f129b94de9fc631666c4cb9789e1ac6b,lebrec2022,sea_level_indicator,6.2.1. Beach shoreface,narrative_fallback_1,,,inferred_map,,-30.0,MSL,reported,submerged_beach,narrative fallback: submerged geomorphic sea-level feature,"[-32.5, -27.5]",null,other,"submerged beach at 6.2.1. Beach shoreface, reported around 30 m depth",6.2.1. Beach shoreface,Morphology and distribution of submerged palaeoshorelines: Insights from the North West Shelf of Australia,https://doi.org/10.1016/j.earscirev.2021.103864,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""6.2.1. Beach shoreface"", ""quote_or_paraphrase"": ""nd were observed offshore Dampier and Broome in water depth of 30 m and 125 m, respectively. Individual clinothems are 1 to 5 m thick and extends over 600 m (Fig. 10). Such morphologies correspond to the description of \u201cshoreline clinoforms\u201d (Patruno and Helland-Hansen, 2018), which encompasses delta front and beach shoreface deposits. Given that no major fluvial systems are identified in their direct vicinity, we interpret these features as beach shoreface strata accumulated by wave processes. This interpretation is supported by the clinoforms angles, < 0.1 degree, which are below the expected threshold of delta front mouth bars (Cosgrove et al., 2018; Paumard et al., 2019; Paumard et al., 2020) and by the presence of relict beach ridges landward of the clinothems.""}","{""reported_elevation_m"": null, ""reported_depth_m"": 30.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""other"", ""relation"": ""unknown"", ""age_ka"": null, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-30,-30,-30,-30
19a122539ed4a2ba17f3b3cc8a2d653d4aaf6f2cd0d76295183b50c762e0197b,lebrec2022,sea_level_indicator,6.3. Marine terraces,narrative_fallback_2,,,inferred_map,,-17.0,MSL,reported,marine_terrace,narrative fallback: submerged geomorphic sea-level feature,"[-19.5, -14.5]",null,other,"marine terrace at 6.3. Marine terraces, reported around 17 m depth",6.3. Marine terraces,Morphology and distribution of submerged palaeoshorelines: Insights from the North West Shelf of Australia,https://doi.org/10.1016/j.earscirev.2021.103864,0.55,Narrative fallback cluster from prose description of submerged palaeolandscape; depth uncertainty widened pending human review.,"{""page"": null, ""figure"": null, ""table"": null, ""section"": ""6.3. Marine terraces"", ""quote_or_paraphrase"": ""Sub-horizontal terraces are observed from both the bathymetry and the 2D seismic data at depths of 17, 35 and 90 m. They are characterised by gentle seaward dipping surfaces and are backed by a terrace riser (Fig. 12B\u2013E). Both criteria are distinctive morphologies of marine terraces formed through wave erosion (Anderson et al., 1999; Blanchon and Jones, 1995; Bradley, 1958). Similar features can be observed along the modern coast (Fig. 12E), confirming the nature of the terraces. Within the Dampier Archipelago, a terrace identified at 17 m of water depth from LiDAR bathymetry is rimmed by""}","{""reported_elevation_m"": null, ""reported_depth_m"": 17.0, ""reported_datum"": ""MSL"", ""reported_uncertainty_m"": null}","{""raw_raster_value_m"": null, ""applied_correction_m"": null, ""derived_elevation_m"": null, ""derived_depth_m"": null, ""derivation_notes"": ""Existing elevation preserved; no raster overwrite applied.""}","[{""method"": ""other"", ""relation"": ""unknown"", ""age_ka"": null, ""uncertainty_ka"": null, ""material"": null, ""notes"": ""Narrative fallback age context; review before analytical use.""}]",-17,-17,-17,-17
